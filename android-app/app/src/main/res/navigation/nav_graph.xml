<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.hrmapp.mobile.feature.auth.LoginFragment"
        android:label="Login">
        <action
            android:id="@+id/action_loginFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.hrmapp.mobile.feature.home.HomeFragment"
        android:label="Home" />

    <fragment
        android:id="@+id/attendanceFragment"
        android:name="com.hrmapp.mobile.feature.attendance.AttendanceFragment"
        android:label="Attendance" />

    <fragment
        android:id="@+id/leaveFragment"
        android:name="com.hrmapp.mobile.feature.leave.LeaveFragment"
        android:label="Leave" />

    <fragment
        android:id="@+id/notificationFragment"
        android:name="com.hrmapp.mobile.feature.notification.NotificationFragment"
        android:label="Notification" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.hrmapp.mobile.feature.profile.ProfileFragment"
        android:label="Profile" />

    <fragment
        android:id="@+id/approvalFragment"
        android:name="com.hrmapp.mobile.feature.approval.ApprovalFragment"
        android:label="Approvals" />

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.hrmapp.mobile.feature.dashboard.ManagerDashboardFragment"
        android:label="Dashboard" />
</navigation>