<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card_primary"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvApprovalTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Yêu cầu phê duyệt"
        android:textColor="@color/text_primary"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvApprovalSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Bước 1 • MANAGER"
        android:textColor="@color/text_secondary" />

    <TextView
        android:id="@+id/tvApprovalStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Chờ duyệt"
        android:textColor="@color/warning_orange"
        android:textStyle="bold" />
</LinearLayout>