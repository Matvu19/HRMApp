<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_lg">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home_title"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_h2"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:text="@string/home_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_body" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xl"
            android:background="@drawable/bg_card_primary"
            android:orientation="vertical"
            android:padding="@dimen/space_lg">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_manager_actions"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_h3"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnOpenApproval"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:minHeight="@dimen/button_min_height"
                android:text="@string/home_open_approval" />

            <Button
                android:id="@+id/btnOpenDashboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:minHeight="@dimen/button_min_height"
                android:text="@string/home_open_dashboard" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_lg"
            android:background="@drawable/bg_card_primary"
            android:orientation="vertical"
            android:padding="@dimen/space_lg">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_employee_actions"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_h3"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnOpenAttendance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:minHeight="@dimen/button_min_height"
                android:text="@string/home_open_attendance" />

            <Button
                android:id="@+id/btnOpenLeave"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:minHeight="@dimen/button_min_height"
                android:text="@string/home_open_leave" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>